# CTI-Shield Environment Variables
# Copy this file to .env and fill in your keys

# ── LLM API Keys (optional — Demo mode works without these) ─────────
# Free providers (get keys at the listed URLs):
OPENROUTER_API_KEY=          # https://openrouter.ai (free tier)
GEMINI_API_KEY=              # https://aistudio.google.com (free tier)
GROQ_API_KEY=                # https://console.groq.com (free tier)
CEREBRAS_API_KEY=            # https://cloud.cerebras.ai (free tier)
COHERE_API_KEY=              # https://dashboard.cohere.com (free tier)
GITHUB_TOKEN=                # https://github.com/marketplace/models (free with GitHub)
MISTRAL_API_KEY=             # https://console.mistral.ai (free tier)
HF_TOKEN=                    # https://huggingface.co (free tier)
NVIDIA_API_KEY=              # https://build.nvidia.com (free tier)
SAMBANOVA_API_KEY=           # https://cloud.sambanova.ai (free tier)

# Paid providers:
OPENAI_API_KEY=              # https://platform.openai.com
ANTHROPIC_API_KEY=           # https://console.anthropic.com

# ── Threat Intelligence APIs (optional) ─────────────────────────────
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=

# ── MISP Integration (optional) ─────────────────────────────────────
MISP_API_KEY=
MISP_URL=

# ── TheHive Integration (optional) ──────────────────────────────────
THEHIVE_API_KEY=
THEHIVE_URL=

# ── Application Settings ────────────────────────────────────────────
CTI_SHIELD_DEBUG=false
CTI_SHIELD_LOG_LEVEL=INFO

# ── Ollama (local LLM) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
